{
  "name": "sabi-desktop",
  "version": "0.0.1",
  "private": true,
  "description": "Electron shell for Sabi desktop.",
  "main": "dist-electron/main.js",
  "type": "module",
  "engines": {
    "node": ">=20 <21",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 npm run build:electron && electron .",
    "build": "npm run typecheck && npm run build:electron && npm run build:renderer",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:renderer": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "package": "npm run build && electron-builder --dir --config build/electron-builder.yml",
    "package:mac": "npm run build && node scripts/package-mac.mjs",
    "package:mac:arm64": "npm run build && node scripts/package-mac.mjs --arm64",
    "package:mac:x64": "npm run build && node scripts/package-mac.mjs --x64",
    "package:win": "npm run build && node scripts/package-win.mjs",
    "signing:create-local-cert": "powershell -ExecutionPolicy Bypass -File scripts/create-local-signing-cert.ps1",
    "validate:mac-package": "node scripts/validate-mac-package.mjs",
    "validate:win-package": "node scripts/validate-win-package.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.renderer.json --noEmit"
  },
  "dependencies": {
    "electron-log": "5.4.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.6.0",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "6.0.1",
    "concurrently": "9.2.1",
    "cross-env": "10.1.0",
    "electron": "41.3.0",
    "electron-builder": "26.8.1",
    "eslint": "10.2.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.5.0",
    "jsdom": "29.1.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1",
    "vite": "8.0.10",
    "vitest": "4.1.5",
    "wait-on": "9.0.5"
  }
}
